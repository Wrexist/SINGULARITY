# Fastlane lanes for Singularity Inc. — built entirely on CI (no local Mac).
# The `beta` lane signs with Fastlane Match and uploads to TestFlight using the
# App Store Connect API key. See DEPLOYMENT.md for the full setup + secrets.

default_platform(:ios)

WORKSPACE = "ios/App/App.xcworkspace"
PROJECT = "ios/App/App.xcodeproj"
SCHEME = "App"
BUNDLE_ID = "com.wrexist.singularityinc"

platform :ios do
  desc "Build the Capacitor iOS app and upload it to TestFlight"
  lane :beta do
    # 1) App Store Connect API key (JWT) — auth for Match + the upload. No 2FA.
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: "fastlane/AuthKey.p8", # written from ASC_KEY_P8 in the workflow
      in_house: false,
    )

    # 2) Fetch (or create, on first run) the distribution cert + App Store profile.
    match(
      type: "appstore",
      app_identifier: [BUNDLE_ID],
      api_key: api_key,
      readonly: false, # set true once the Match repo is populated for this app
    )

    # 3) Point the generated Xcode project at the Match profile (manual signing).
    update_code_signing_settings(
      path: PROJECT,
      use_automatic_signing: false,
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      code_sign_identity: "Apple Distribution",
      bundle_identifier: BUNDLE_ID,
      profile_name: "match AppStore #{BUNDLE_ID}",
      targets: ["App"],
    )

    # 4) Unique, increasing build number (App Store rejects duplicates).
    increment_build_number(
      xcodeproj: PROJECT,
      build_number: ENV["BUILD_NUMBER"] || Time.now.to_i.to_s,
    )

    # 5) Archive + export the IPA.
    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: { BUNDLE_ID => "match AppStore #{BUNDLE_ID}" },
      },
    )

    # 6) Upload to TestFlight (don't block CI on Apple-side processing).
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: ENV["TF_CHANGELOG"] || "Phase 1 beta — hall, prestige, research, events.",
    )
  end
end
